-- ============================================================
--  АНИМАЦИЯ  ОТКРЫТЬ / ЗАКРЫТЬ
--  Меню выезжает из кнопки XENO и расширяется
-- ============================================================
local isOpen   = false
local animLock = false

-- Позиция кнопки XENO (откуда выезжает меню)
local BTN_POS_X = 16
local BTN_POS_Y = 16

local SIZE_FINAL = UDim2.new(0, MENU_W, 0, MENU_H)
local POS_FINAL  = UDim2.new(0, BTN_POS_X, 0, BTN_POS_Y + BTN_H + 6)
local SIZE_START = UDim2.new(0, BTN_W, 0, BTN_H)
local POS_START  = UDim2.new(0, BTN_POS_X, 0, BTN_POS_Y + BTN_H + 6)

local function showBody(v)
    local tr = v and 0 or 1
    tweenQ(header, 0.18, {BackgroundTransparency = tr}):Play()
    tweenQ(divH,   0.18, {BackgroundTransparency = tr}):Play()
    tweenQ(tabBar, 0.18, {BackgroundTransparency = tr}):Play()
    if v then
        tweenQ(closeBtn, 0.18, {BackgroundTransparency=0, TextTransparency=0}):Play()
    else
        tweenQ(closeBtn, 0.12, {BackgroundTransparency=1, TextTransparency=1}):Play()
    end
    for i = 1, #tabPages do
        tabPages[i].Parent.Visible = v and (i == activeTab)
    end
end

local function openMenu()
    if animLock or isOpen then return end
    animLock = true

    -- Сброс
    menu.Size     = SIZE_START
    menu.Position = POS_START
    menu.BackgroundTransparency = 0.6
    showBody(false)
    menu.Visible  = true

    -- Шаг 1: fade in (0.15 с)
    tweenQ(menu, 0.15, {BackgroundTransparency = 0}):Play()
    task.wait(0.12)

    -- Шаг 2: расширение вниз — меню вырастает из кнопки (Back easing, 0.42 с)
    tweenBack(menu, 0.42, {Size = SIZE_FINAL}):Play()
    task.wait(0.22)

    -- Шаг 3: пока меню ещё расширяется — проявляем контент
    showBody(true)

    task.wait(0.24)
    isOpen   = true
    animLock = false
end

local function closeMenu()
    if animLock or not isOpen then return end
    animLock = true

    -- Шаг 1: скрыть контент
    showBody(false)
    task.wait(0.12)

    -- Шаг 2: схлопнуть меню обратно в кнопку
    tweenExp(menu, 0.32, {Size = SIZE_START, BackgroundTransparency = 0.5}):Play()
    task.wait(0.28)

    -- Шаг 3: fade out
    tweenQ(menu, 0.16, {BackgroundTransparency = 1}):Play()
    task.wait(0.18)

    menu.Visible = false
    isOpen   = false
    animLock = false
end

-- ============================================================
--  ПРИВЯЗКИ
-- ============================================================
xenoBtn.MouseButton1Click:Connect(function()
    if isOpen then task.spawn(closeMenu)
    else           task.spawn(openMenu) end
end)

closeBtn.MouseButton1Click:Connect(function()
    task.spawn(closeMenu)
end)

UserInputService.InputBegan:Connect(function(inp, proc)
    if proc then return end
    if inp.KeyCode == OPEN_KEY then
        if isOpen then task.spawn(closeMenu)
        else           task.spawn(openMenu) end
    end
end)

