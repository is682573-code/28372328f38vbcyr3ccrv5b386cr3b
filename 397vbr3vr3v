--  ХЕЛПЕР: ТУМБЛЕР
-- ============================================================
local function createToggle(scroll, labelText, default, cb)
    local ROW_H = 40
    local row = fr(scroll, UDim2.new(1,-4,0,ROW_H), UDim2.new(0,2,0,0), C.SURFACE)
    row.LayoutOrder = #scroll:GetChildren()
    corner(row, 6)

    lbl(row, labelText,
        UDim2.new(1,-72,1,0), UDim2.new(0,14,0,0),
        12, C.TEXT, Enum.Font.Gotham)

    local track = fr(row, UDim2.new(0,44,0,25), UDim2.new(1,-56,0.5,-12), C.RED)
    corner(track, 13)
    local ts = stroke(track, C.RED_BORDER, 1)

    local knob = fr(track, UDim2.new(0,21,0,21), UDim2.new(0,2,0.5,-10), C.KNOB)
    corner(knob, 11)

    local val = default or false

    local function set(v, anim)
        val = v
        local kp = v and UDim2.new(0,21,0.5,-10) or UDim2.new(0,2,0.5,-10)
        local tc = v and C.GREEN or C.RED
        local bc = v and C.GREEN_BORDER or C.RED_BORDER
        local ti = TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        if anim then
            TweenService:Create(knob,  ti, {Position=kp}):Play()
            TweenService:Create(track, ti, {BackgroundColor3=tc}):Play()
            TweenService:Create(ts,    ti, {Color=bc}):Play()
        else
            knob.Position=kp; track.BackgroundColor3=tc; ts.Color=bc
        end
        if cb then cb(val) end
    end
    set(val, false)

    local cb2 = Instance.new("TextButton")
    cb2.Size=UDim2.new(1,0,1,0); cb2.BackgroundTransparency=1
    cb2.Text=""; cb2.AutoButtonColor=false; cb2.Parent=row
    cb2.MouseButton1Click:Connect(function() set(not val,true) end)
    cb2.MouseEnter:Connect(function() tweenQ(row,0.1,{BackgroundColor3=C.SURFACE2}):Play() end)
    cb2.MouseLeave:Connect(function() tweenQ(row,0.1,{BackgroundColor3=C.SURFACE}):Play() end)

    return {getValue=function() return val end, setValue=function(v) set(v,true) end}
end

-- ============================================================
--  ХЕЛПЕР: КНОПКА
-- ============================================================
local function createButton(scroll, labelText, cb)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,-4,0,38)
    btn.BackgroundColor3 = C.BTN; btn.BorderSizePixel = 0
    btn.Text = labelText; btn.TextColor3 = C.TEXT
    btn.Font = Enum.Font.Gotham; btn.TextSize = 12
    btn.AutoButtonColor = false; btn.Parent = scroll
    btn.LayoutOrder = #scroll:GetChildren()
    corner(btn, 6); stroke(btn, C.BORDER, 1)
    btn.MouseEnter:Connect(function() tweenQ(btn,0.12,{BackgroundColor3=C.BTN_HOVER}):Play() end)
    btn.MouseLeave:Connect(function() tweenQ(btn,0.12,{BackgroundColor3=C.BTN}):Play() end)
    btn.MouseButton1Click:Connect(function() if cb then cb() end end)
    return btn
end

