    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, tabBtnW, 1, 0)
    btn.Position = UDim2.new(0, (i-1)*tabBtnW, 0, 0)
    btn.BackgroundTransparency = 1; btn.BorderSizePixel = 0
    btn.Text = name
    btn.TextColor3 = (i==1) and C.WHITE or C.TEXT_DIM
    btn.Font = Enum.Font.Gotham; btn.TextSize = 11
    btn.AutoButtonColor = false; btn.Parent = tabBar

    local ind = fr(btn, UDim2.new(0.6,0,0,2), UDim2.new(0.2,0,1,-2), C.WHITE)
    ind.BackgroundTransparency = (i==1) and 0 or 1

    tabButtons[i] = {btn=btn, ind=ind}

    -- Страница вкладки
    local PAGE_Y = TAB_BAR_Y + TAB_BAR_H + 2
    local page   = fr(menu,
        UDim2.new(1,-14, 1, -(PAGE_Y+8)),
        UDim2.new(0,7,0,PAGE_Y),
        C.BG, 1)
    page.ClipsDescendants = true
    page.Visible          = (i==1)
    tabPages[i]           = page

    -- Скроллинг для длинного контента
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1,0,1,0)
    scroll.Position = UDim2.new(0,0,0,0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = C.BORDER
    scroll.CanvasSize = UDim2.new(0,0,0,0)   -- авто через UIListLayout
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.Parent = page

    local list = Instance.new("UIListLayout")
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Padding = UDim.new(0,4)
    list.Parent = scroll

    tabPages[i] = scroll   -- контент добавляем в scroll

    btn.MouseButton1Click:Connect(function()
        if activeTab == i then return end
        tabPages[activeTab].Parent.Visible = false
        tabButtons[activeTab].btn.TextColor3 = C.TEXT_DIM
        tabButtons[activeTab].ind.BackgroundTransparency = 1
        activeTab = i
        tabPages[i].Parent.Visible = true
        tabButtons[i].btn.TextColor3 = C.WHITE
        tabButtons[i].ind.BackgroundTransparency = 0
    end)
    btn.MouseEnter:Connect(function() if activeTab~=i then btn.TextColor3=Color3.fromRGB(155,155,168) end end)
    btn.MouseLeave:Connect(function() if activeTab~=i then btn.TextColor3=C.TEXT_DIM end end)
end

