local function caesarCipher(inputStr, shift)
  local resultChars = {}
  local shiftAmount = 7
  for charIdx = 1, #inputStr, 1 do
    local charCode = string.byte(inputStr, charIdx)
    if 65 <= charCode and charCode <= 90 then
      local baseCode = 65
      table.insert(resultChars, string.char((charCode - baseCode + shiftAmount) % 26 + baseCode))
    elseif 97 <= charCode and charCode <= 122 then
      local baseCode = 97
      table.insert(resultChars, string.char((charCode - baseCode + shiftAmount) % 26 + baseCode))
    else
      table.insert(resultChars, string.char(charCode))
    end
  end
  return table.concat(resultChars)
end
local function isBossAlive(zoneName, bossName, attributeName)
