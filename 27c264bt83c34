function Save(value, filename)
  if typeof(value) == "UDim2" then
    local udim2String = value.X.Scale .. "," .. value.X.Offset .. "," .. value.Y.Scale .. "," .. value.Y.Offset
    if not filename:match("%.txt$") then
      filename = filename .. ".txt"
    end
    writefile(filename, udim2String)
  else
    writefile(filename, tostring(value))
  end
end
