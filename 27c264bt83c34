function Load(valueType, filePath)
  if not isfile(filePath) then
    return nil
  end
  if valueType == "UDim2" then
    local xScale, xOffset, yScale, yOffset = string.match(readfile(filePath), "([%d%.%-]+),([%d%.%-]+),([%d%.%-]+),([%d%.%-]+)")
    if xScale and yScale then
      return UDim2.new(tonumber(xScale), tonumber(xOffset), tonumber(yScale), tonumber(yOffset))
    end
    return nil
  end
  return readfile(filePath)
end

