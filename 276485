function GGshopGUI.createSlider(parent, tbl, key, name, minv, maxv, format)
    local sFrame = Instance.new("Frame")
    sFrame.Parent = parent
    sFrame.BackgroundColor3 = COLORS.GRAY_MED
    sFrame.BackgroundTransparency = 0.3
    sFrame.Size = UDim2.new(1, -10, 0, 60)
