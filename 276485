local defaultSettings = nil
local lastProfileFile = Settings.Config.SavePath .. "last_profile.txt"
local FS_AVAILABLE = (type(writefile) == "function" and type(readfile) == "function" and type(isfolder) == "function" and type(makefolder) == "function")

if not FS_AVAILABLE then
    warn("⚠️ [GGshop] Файловая система не поддерживается. Конфиги не будут сохраняться.")
end

local function ensureConfigPath()
    if not FS_AVAILABLE then return false end
    local path = Settings.Config.SavePath
    if not isfolder(path) then
        local success = pcall(makefolder, path)
        if not success then warn("[GGshop] Не удалось создать папку: " .. tostring(path)); return false end
    end
    return true
end

function SaveConfig(profileName)
    profileName = profileName or Settings.Config.ProfileName
    if profileName == "" then return end
    if not FS_AVAILABLE then return end
    if not ensureConfigPath() then return end
    local saveTable = {
        ESP = Settings.ESP, BotsAim = Settings.BotsAim, Misc = Settings.Misc,
        Combat = Settings.Combat, AdminESP = Settings.AdminESP, Visuals = Settings.Visuals,
        BulletPhysics = Settings.BulletPhysics, SpeedHack = Settings.SpeedHack, AutoLoot = Settings.AutoLoot,
        WeaponStats = Settings.WeaponStats, NPCESP = Settings.NPCESP, Zoom = Settings.Zoom,
        MapESP = Settings.MapESP, Customization = Settings.Customization,
        NoVisors = Settings.NoVisors, NoFlashbang = Settings.NoFlashbang,
        LootESP = Settings.LootESP, MenuKey = Settings.MenuKey,
    }
    local success, json = pcall(function() return HttpService:JSONEncode(saveTable) end)
    if not success then return end
    local path = Settings.Config.SavePath .. profileName .. ".json"
    pcall(function() writefile(path, json) end)
    pcall(function() writefile(lastProfileFile, profileName) end)
end

function LoadConfig(profileName)
    profileName = profileName or Settings.Config.ProfileName
    if profileName == "" or not FS_AVAILABLE then return end
    local path = Settings.Config.SavePath .. profileName .. ".json"
    local success, data = pcall(readfile, path)
    if not success then return end
    local decoded = HttpService:JSONDecode(data)
    if not decoded then return end
    local function merge(t, s)
        for k, v in pairs(s) do
            if type(v) == "table" and type(t[k]) == "table" then merge(t[k], v) else t[k] = v end
        end
    end
    merge(Settings, decoded)
    ApplyNightVision(Settings.Misc.NightVision)
    ApplyNoVisors(Settings.NoVisors.Enabled)
    updateTabContent(currentTab)
end

function ResetToDefaults()
    if not defaultSettings then defaultSettings = HttpService:JSONDecode(HttpService:JSONEncode(Settings)) end
    local function merge(t, s)
        for k, v in pairs(s) do
            if type(v) == "table" and type(t[k]) == "table" then merge(t[k], v) else t[k] = v end
        end
    end
    merge(Settings, defaultSettings)
    ApplyNightVision(Settings.Misc.NightVision)
    ApplyNoVisors(Settings.NoVisors.Enabled)
    updateTabContent(currentTab)
end

