local TRADER_NAMES = { "Tarmo", "Blaze", "George", "Mikhel", "Trader", "Medic", "Mechanic" }
local NPCPositionCache = {}

local function GetNPCCenterPoint(character)
    local parts = {}
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("BasePart") then
            table.insert(parts, child)
        end
    end
    if #parts == 0 then return nil, nil end
    local center = Vector3.new(0,0,0)
    local minY, maxY = math.huge, -math.huge
    for _, part in ipairs(parts) do
        center = center + part.Position
        minY = math.min(minY, part.Position.Y)
        maxY = math.max(maxY, part.Position.Y)
    end
    center = center / #parts
    return center, maxY - minY
end

local function IsTrader(character)
    local name = character.Name
    for _, trader in ipairs(TRADER_NAMES) do
        if name:find(trader, 1, true) then return true end
    end
    return false
end

local function GetNPCFaction(character)
    local name = character.Name:lower()
    if name:find("dozer") or name:find("anton") or name:find("scav king") or name:find("whisper") or name:find("anton guard") then
        return "Boss"
    elseif name:find("bandit") or name:find("highwayman") or name:find("rat") then
        return "Bandit"
    elseif name:find("occupant") or name:find("soviet") or name:find("mkb") then
        return "Soviet"
    elseif name:find("task force") or name:find("tfz") then
        return "TFZ"
    elseif name:find("scav") then
        return "Scav"
    elseif name:find("uno") then
        return "UNO"
    elseif IsTrader(character) then
        return "Trader"
    else
        return "Other"
    end
end

local function IsValidNPC(character)
    if not character:IsA("Model") then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    if Players:GetPlayerFromCharacter(character) then return false end
    if IsTrader(character) then return true end
    local partCount = 0
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("BasePart") then partCount = partCount + 1 end
    end
    if partCount < 5 then return false end
    if humanoid.MaxHealth < 80 then return false end
    return true
end

