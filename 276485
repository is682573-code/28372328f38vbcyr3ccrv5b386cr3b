-- ZOOM (ПЛАВНЫЙ)
-- ████████████████████████████████████████████████████████████
local zoomActive = false
local zoomToggled = false
local storedFOV = Camera.FieldOfView
local zoomTween = nil

local function UpdateStoredFOV()
    if not (zoomActive or zoomToggled) then
        storedFOV = Camera.FieldOfView
    end
end

Camera:GetPropertyChangedSignal("FieldOfView"):Connect(UpdateStoredFOV)
LocalPlayer.CharacterAdded:Connect(UpdateStoredFOV)

local function setZoomFOV(targetFOV, duration)
    if zoomTween then zoomTween:Cancel() end
    zoomTween = TweenService:Create(Camera, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {FieldOfView = targetFOV})
    zoomTween:Play()
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if Settings.Zoom.Enabled and input.KeyCode == Settings.Zoom.Key then
        if Settings.Zoom.Mode == "Hold" then
            zoomActive = true
            setZoomFOV(Settings.Zoom.ZoomFOV, Settings.Zoom.Speed)
        else
            zoomToggled = not zoomToggled
            if zoomToggled then
                setZoomFOV(Settings.Zoom.ZoomFOV, Settings.Zoom.Speed)
            else
                setZoomFOV(storedFOV, Settings.Zoom.Speed)
            end
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, gpe)
    if gpe then return end
    if Settings.Zoom.Enabled and input.KeyCode == Settings.Zoom.Key and Settings.Zoom.Mode == "Hold" then
        zoomActive = false
        setZoomFOV(storedFOV, Settings.Zoom.Speed)
    end
end)

