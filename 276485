local visorCacheGUI = {}
local EFFECT_KEYWORDS = {
    "overlay", "effect", "blur", "vignette", "damage", "scopeoverlay",
    "flash", "bang", "muzzle", "grain", "noise", "scanlines",
    "scope", "sight", "reticle", "zoom", "shield", "glass",
    "faceplate", "faceshield", "goggles", "mask",
}
local SAFE_KEYWORDS = {
    "inventory", "backpack", "hotbar", "slot", "icon", "item", "tool",
    "weapon", "ammo", "magazine", "container", "storage", "equip", "gear",
    "health", "hunger", "thirst", "rad", "stamina", "armor", "durability",
    "minimap", "map", "compass", "waypoint", "marker", "quest",
    "crosshair", "reticule", "name", "tag", "distance", "indicator",
    "menu", "settings", "option", "button", "slider", "checkbox", "dropdown",
    "chat", "console", "message", "notification",
    "roblox", "gamepad", "exit", "pause", "confirm", "popup", "dialog", "modal",
    "inspect", "properties", "stats", "details", "info", "tooltip", "hover",
    "context", "options", "actions", "modify", "settings", "preferences", "configure",
    "helmet", "visor", "armor", "equipment", "attachment", "modification",
    "repair", "condition", "requirements", "equip", "unequip",
    "remove", "attach", "detach", "upgrade", "craft", "mod",
    "iteminfo", "itemstats", "itemdetails", "itemoptions",
    "key", "hint", "input", "control", "guide", "instruction",
    "button", "hotkey", "shortcut", "prompt", "bind", "press",
}

local function stringContainsAny(str, keywords)
    if not str then return false end
    local lower = str:lower()
    for _, kw in ipairs(keywords) do
        if lower:find(kw, 1, true) then return true end
    end
    return false
end

local function isProtected(obj)
    if stringContainsAny(obj.Name, SAFE_KEYWORDS) then return true end
    local parent = obj.Parent
    while parent do
        if stringContainsAny(parent.Name, SAFE_KEYWORDS) then return true end
        if parent:IsA("ScreenGui") and stringContainsAny(parent.Name, SAFE_KEYWORDS) then return true end
        parent = parent.Parent
    end
    return false
end

local function disableGUIEffect(obj)
    if isProtected(obj) then return end
    if obj:IsA("ScreenGui") then
        if stringContainsAny(obj.Name, EFFECT_KEYWORDS) then
            visorCacheGUI[obj] = { type = "ScreenGui", originalEnabled = obj.Enabled }
            obj.Enabled = false
        end
    elseif obj:IsA("Frame") or obj:IsA("ImageLabel") or obj:IsA("TextLabel") then
        if stringContainsAny(obj.Name, EFFECT_KEYWORDS) then
            visorCacheGUI[obj] = { type = "GuiObject", originalVisible = obj.Visible }
            obj.Visible = false
        end
    end
end

local function ApplyNoVisors(enable)
    if enable then
        local containers = {CoreGui, Camera}
        if LocalPlayer.PlayerGui then table.insert(containers, LocalPlayer.PlayerGui) end
        for _, container in ipairs(containers) do
            for _, obj in ipairs(container:GetDescendants()) do
                disableGUIEffect(obj)
            end
        end
    else
        for obj, data in pairs(visorCacheGUI) do
            if obj and obj.Parent then
                pcall(function()
                    if data.type == "ScreenGui" then
                        obj.Enabled = data.originalEnabled
                    else
                        obj.Visible = data.originalVisible
                    end
                end)
            end
        end
        visorCacheGUI = {}
    end
end

local function onDescendantAdded(obj)
    if Settings.NoVisors.Enabled then
        disableGUIEffect(obj)
    end
end

CoreGui.DescendantAdded:Connect(onDescendantAdded)
Camera.DescendantAdded:Connect(onDescendantAdded)
if LocalPlayer.PlayerGui then
    LocalPlayer.PlayerGui.DescendantAdded:Connect(onDescendantAdded)
end

ApplyNoVisors(Settings.NoVisors.Enabled)

