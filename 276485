    label.Text = name .. ": " .. tostring(tbl[key]) .. (format or "")
    label.TextColor3 = COLORS.WHITE
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    local slider = Instance.new("Frame")
    slider.Parent = sFrame
    slider.BackgroundColor3 = COLORS.GRAY_DARK
    slider.Size = UDim2.new(1, -30, 0, 6)
    slider.Position = UDim2.new(0, 15, 0, 35)
    local fill = Instance.new("Frame")
    fill.Parent = slider
    fill.BackgroundColor3 = COLORS.PINK_HOT
    fill.Size = UDim2.new((tbl[key] - minv) / (maxv - minv), 0, 1, 0)
    fill.BorderSizePixel = 0
    local btn = Instance.new("TextButton")
    btn.Parent = sFrame
    btn.BackgroundTransparency = 1
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.Text = ""
    local descText = name .. " (" .. minv .. " - " .. maxv .. ")"
    btn.MouseEnter:Connect(function()
        GGshopGUI.tooltip.Text = descText
        local mp = UserInputService:GetMouseLocation()
        GGshopGUI.tooltip.Position = Vector2.new(mp.X + 15, mp.Y + 15)
        GGshopGUI.tooltip.Visible = true
    end)
    btn.MouseLeave:Connect(function() GGshopGUI.tooltip.Visible = false end)
    local dragging = false
    local function updateFromMouse(input)
        local mousePos = input.Position
        local sliderPos = slider.AbsolutePosition
        local sliderSize = slider.AbsoluteSize.X
        if sliderSize == 0 then return end
        local rel = math.clamp(mousePos.X - sliderPos.X, 0, sliderSize)
        local percent = rel / sliderSize
        local newVal = minv + (maxv - minv) * percent
        newVal = math.floor(newVal * 100) / 100
        tbl[key] = newVal
        fill.Size = UDim2.new(percent, 0, 1, 0)
        label.Text = name .. ": " .. tostring(newVal) .. (format or "")
    end
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateFromMouse(input)
        end
    end)
    btn.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            updateFromMouse(input)
        end
    end)
    btn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

