local function GetPlayerUnderCrosshairIgnoreAll()
    local currentCam = Workspace.CurrentCamera
    local rayOrigin = currentCam.CFrame.Position
    local rayDirection = (currentCam.CFrame.LookVector * 10000).Unit
    local closestPlayer = nil
    local closestDistance = math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if not rootPart then continue end
        local charSize = 3
        local rootPos = rootPart.Position
        local toTarget = rootPos - rayOrigin
        local projection = toTarget:Dot(rayDirection)
        if projection < 0 then continue end
        local closestPointOnRay = rayOrigin + rayDirection * projection
        local distanceToRay = (rootPos - closestPointOnRay).Magnitude
        if distanceToRay <= charSize and projection < closestDistance then
            closestDistance = projection
            closestPlayer = plr
        end
    end
    return closestPlayer
end

