-- ████████████████████████████████████████████████████████████
-- ФУНКЦИИ ОБНОВЛЕНИЯ ESP
-- ████████████████████████████████████████████████████████████
local function UpdateESP()
    local espSet = Settings.ESP
    local viewportSize = Camera.ViewportSize

    if espSet.Enabled then
        local myTeam = LocalPlayer.Team
        for plr, esp in pairs(Settings.ESPObjects) do
            if plr == LocalPlayer then
                esp.BoxOutline.Visible = false
                esp.BoxFill.Visible = false
                esp.HealthBg.Visible = false
                esp.HealthFill.Visible = false
                esp.NameText.Visible = false
                esp.DistanceText.Visible = false
                esp.PrimaryWeaponText.Visible = false
                esp.SecondaryWeaponText.Visible = false
                esp.Tracer.Visible = false
                continue
            end

            local char = plr.Character
            local rootPart = char and char:FindFirstChild("HumanoidRootPart")
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            if not (char and rootPart and humanoid and humanoid.Health > 0) then
                esp.BoxOutline.Visible = false
                esp.BoxFill.Visible = false
                esp.HealthBg.Visible = false
                esp.HealthFill.Visible = false
                esp.NameText.Visible = false
                esp.DistanceText.Visible = false
                esp.PrimaryWeaponText.Visible = false
                esp.SecondaryWeaponText.Visible = false
                esp.Tracer.Visible = false
                continue
            end

            if espSet.TeamCheck and plr.Team == myTeam then
                esp.BoxOutline.Visible = false
                esp.BoxFill.Visible = false
                esp.HealthBg.Visible = false
                esp.HealthFill.Visible = false
                esp.NameText.Visible = false
                esp.DistanceText.Visible = false
                esp.PrimaryWeaponText.Visible = false
                esp.SecondaryWeaponText.Visible = false
                esp.Tracer.Visible = false
                continue
            end

            local dist = (Camera.CFrame.Position - rootPart.Position).Magnitude
            if dist > espSet.MaxDistance then
                esp.BoxOutline.Visible = false
                esp.BoxFill.Visible = false
                esp.HealthBg.Visible = false
                esp.HealthFill.Visible = false
                esp.NameText.Visible = false
                esp.DistanceText.Visible = false
                esp.PrimaryWeaponText.Visible = false
                esp.SecondaryWeaponText.Visible = false
                esp.Tracer.Visible = false
                continue
            end

            local visible = true
            if espSet.VisCheck then
                visible = IsTargetVisible(char, {"Head"})
            end

            local healthPercent = humanoid.Health / humanoid.MaxHealth
            local healthColor = COLORS.HEALTH_GREEN:Lerp(COLORS.HEALTH_RED, 1 - healthPercent)
            local outlineColor = visible and COLORS.VISIBLE_GREEN or COLORS.INVISIBLE_RED
            local nameColor = visible and espSet.Name.Color or COLORS.INVISIBLE_RED
            local distanceColor = visible and COLORS.DISTANCE_COLOR or COLORS.INVISIBLE_RED
            local primaryColor = visible and espSet.Weapon.Color or COLORS.INVISIBLE_RED
            local secondaryColor = visible and espSet.SecondaryWeapon.Color or COLORS.INVISIBLE_RED

            local head = char:FindFirstChild("Head")
            if head then
                local headVec, onScreenHead = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.5,0))
                local footVec, onScreenFoot = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0,2.5,0))
                if onScreenHead and onScreenFoot then
                    local height = math.abs(headVec.Y - footVec.Y)
                    local width = height * 0.5
                    local centerX = headVec.X
                    local boxPos = Vector2.new(centerX - width/2, math.min(headVec.Y, footVec.Y))
                    local boxSize = Vector2.new(width, height)

                    if espSet.Box.Enabled and espSet.Box.Outline then
                        esp.BoxOutline.Position = boxPos
                        esp.BoxOutline.Size = boxSize
                        esp.BoxOutline.Color = outlineColor
                        esp.BoxOutline.Visible = true
                    else
                        esp.BoxOutline.Visible = false
                    end

                    if espSet.HealthBar.Enabled then
                        local barWidth = 4
                        local barX = (espSet.HealthBar.Position == "Left") and (boxPos.X - barWidth - 2) or (boxPos.X + boxSize.X + 2)
                        local barPos = Vector2.new(barX, boxPos.Y)
                        local barHeight = boxSize.Y

                        esp.HealthBg.Position = barPos
                        esp.HealthBg.Size = Vector2.new(barWidth, barHeight)
                        esp.HealthBg.Visible = true

                        local fillHeight = barHeight * healthPercent
                        esp.HealthFill.Position = Vector2.new(barPos.X, barPos.Y + barHeight - fillHeight)
                        esp.HealthFill.Size = Vector2.new(barWidth, fillHeight)
                        esp.HealthFill.Color = healthColor
                        esp.HealthFill.Visible = true
                    else
                        esp.HealthBg.Visible = false
                        esp.HealthFill.Visible = false
                    end

                    if espSet.Weapon.Enabled then
                        local primary, secondary = GetPlayerWeaponInfo(plr)
                        if primary.name ~= "" then
                            local weaponText = primary.name
                            if espSet.Weapon.ShowAmmo and primary.damage > 0 then
                                weaponText = weaponText .. string.format(" [%d", primary.damage)
                                if primary.pen > 0 then weaponText = weaponText .. "|" .. primary.pen end
                                weaponText = weaponText .. "]"
                            end
                            esp.PrimaryWeaponText.Text = weaponText
                            esp.PrimaryWeaponText.Position = Vector2.new(headVec.X, boxPos.Y - 36)
                            esp.PrimaryWeaponText.Color = primaryColor
                            esp.PrimaryWeaponText.Visible = true
                        else
                            esp.PrimaryWeaponText.Visible = false
                        end

                        if secondary.name ~= "" then
                            local weaponText = secondary.name
                            if espSet.SecondaryWeapon.ShowAmmo and secondary.damage > 0 then
                                weaponText = weaponText .. string.format(" [%d", secondary.damage)
                                if secondary.pen > 0 then weaponText = weaponText .. "|" .. secondary.pen end
                                weaponText = weaponText .. "]"
                            end
                            esp.SecondaryWeaponText.Text = weaponText
                            esp.SecondaryWeaponText.Position = Vector2.new(headVec.X, boxPos.Y + 4)
                            esp.SecondaryWeaponText.Color = secondaryColor
                            esp.SecondaryWeaponText.Visible = true
                        else
                            esp.SecondaryWeaponText.Visible = false
                        end
                    else
                        esp.PrimaryWeaponText.Visible = false
                        esp.SecondaryWeaponText.Visible = false
                    end

                    if espSet.Tracer.Enabled then
                        esp.Tracer.From = Vector2.new(viewportSize.X / 2, viewportSize.Y)
                        esp.Tracer.To = Vector2.new(headVec.X, headVec.Y)
                        esp.Tracer.Color = outlineColor
                        esp.Tracer.Visible = true
                    else
                        esp.Tracer.Visible = false
                    end

                    if espSet.Name.Enabled then
                        local nameText = plr.Name
                        if espSet.Name.ShowHealth then
